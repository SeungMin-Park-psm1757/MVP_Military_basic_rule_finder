# Required
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.0-flash
GEMINI_DAILY_REQUEST_BUDGET=200
GEMINI_DAILY_TOKEN_BUDGET=1000000
GEMINI_BUDGET_CUTOFF_RATIO=0.9

# Optional: only needed for full law.go.kr Open API collection
LAW_API_KEY=your_law_go_kr_open_api_key_here

# Optional overrides
APP_DAILY_LIMIT=20
APP_MAX_QUESTION_CHARS=600
APP_ALLOW_DEBUG_TAB=false
APP_CHROMA_PATH=data/chroma
APP_RUNTIME_DIR=data/runtime
CHROMA_COLLECTION_NAME=army_reg_rag
